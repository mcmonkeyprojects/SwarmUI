    - ui
    - tools

SeedVR2Upscaler:
    author: Rasmus
    description: Adds SeedVR2 AI upscaler with auto VRAM detection, quality presets, and 2-step upscaling for reduced artifacts.
    url: https://github.com/rlerdorf/SwarmUI-SeedVR2Upscaler
    license: MIT
    ci-test: true
    tags:
    - parameters
    - nodes

Base2Edit:
    author: Juan Treminio
    description: Edit an image in the refiner stage (with Edit models like Flux2), allowing you to generate and edit in a single generation.
    url: https://github.com/jtreminio/SwarmUI-Base2Edit
    license: MIT
    ci-test: true
    tags:
    - parameters
    - nodes

WhatTheDuck:
