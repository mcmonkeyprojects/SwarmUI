{
  "name": "swarmui-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/electron-dev.cjs",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "node scripts/build-runtime.mjs electron",
    "build:integrated": "npm run build && node scripts/build-integrated.mjs",
    "build:win": "npm run build:electron && electron-builder --win",
    "build:mac": "npm run build:electron && electron-builder --mac",
    "build:linux": "npm run build:electron && electron-builder --linux",
    "test": "vitest run",
    "lint": "eslint .",
    "audit:prompt-wizard": "node scripts/prompt-wizard-audit.mjs",
    "theme:audit": "node scripts/theme-audit.mjs",
    "theme:contrast-audit": "node scripts/theme-contrast-audit.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mantine/core": "^9.2.0",
    "@mantine/form": "^9.2.0",
    "@mantine/hooks": "^9.2.0",
    "@mantine/notifications": "^9.2.0",
    "@mantine/tiptap": "^9.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "blurhash": "^2.0.5",
    "comlink": "^4.4.2",
    "downshift": "^9.0.13",
    "framer-motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-draggable": "^4.5.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/remote": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.1.2",
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.3.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6",
    "wait-on": "^8.0.1",
    "workbox-window": "^7.4.1"
  },
  "build": {
    "appId": "com.swarmui.react",
    "productName": "SwarmUI",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/icon.png",
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/icon.png",
      "category": "Graphics"
    },
    "extraResources": [
      {
        "from": "../",
        "to": "swarmui",
        "filter": [
          "**/*",
          "!swarmui-react/**"
        ]
      }
    ]
  }
}
